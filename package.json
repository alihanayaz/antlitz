{
  "name": "antlitz",
  "version": "0.1.0",
  "description": "A minimal design system for React 19 and Tailwind CSS v4.",
  "homepage": "https://github.com/alihanayaz/antlitz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alihanayaz/antlitz.git"
  },
  "bugs": "https://github.com/alihanayaz/antlitz/issues",
  "license": "MIT",
  "author": {
    "name": "Alihan Ayaz",
    "email": "alihan@alihanayaz.com",
    "url": "https://alihanayaz.com"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm build:types && cp src/styles/theme.css dist/theme.css",
    "build:js": "babel src --out-dir dist --extensions \".ts,.tsx\" --config-file ./babel.config.build.json --source-maps",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm build && publint",
    "prepublishOnly": "pnpm check"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7"
  }
}
